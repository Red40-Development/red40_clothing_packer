<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:ClothingRepacker.Gui.Controls"
        x:Class="ClothingRepacker.Gui.Views.MainWindow"
        Title="{Binding Localization[app.title]}"
        Width="1280"
        Height="960"
        MinWidth="980"
        MinHeight="640"
        DragDrop.AllowDrop="True">
  <Grid RowDefinitions="Auto,*" Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
    <Border Grid.Row="0" Padding="16,14" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Classes="section-title"
                       Text="{Binding Localization[app.title]}"
                       Margin="0"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding VersionCheckText}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <Button Click="UpdateAvailable_Click"
                    IsVisible="{Binding IsUpdateAvailable}"
                    MinHeight="0"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip.Tip="{Binding UpdateReleaseUrl}">
              <TextBlock Text="{Binding Localization[update.available]}"
                         TextDecorations="Underline"
                         Foreground="#2B6CB0" />
            </Button>
          </StackPanel>
          <TextBlock Text="{Binding ProjectDisplayName}"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Grid.RowSpan="3" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Bottom">
          <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" VerticalAlignment="Center">
            <StackPanel Spacing="2" VerticalAlignment="Center" HorizontalAlignment="Right">
              <TextBlock Text="{Binding Localization[support.likeThisSoftware]}"
                         FontSize="12"
                         HorizontalAlignment="Right"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              <Button Click="TeamSupport_Click"
                      MinHeight="0"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      Cursor="Hand"
                      ToolTip.Tip="{Binding Localization[support.team]}"
                      HorizontalAlignment="Right">
                <TextBlock Text="{Binding Localization[support.team]}"
                           FontSize="12"
                           TextDecorations="Underline"
                           Foreground="#2B6CB0" />
              </Button>
            </StackPanel>
            <Button Click="StoreLogo_Click"
                    MinHeight="0"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip.Tip="{Binding Localization[support.openStore]}"
                    HorizontalAlignment="Right">
              <Image Source="avares://ClothingRepacker.Gui/Assets/red40_logo.png"
                     Height="72"
                     Stretch="UniformToFill"
                     HorizontalAlignment="Right" />
            </Button>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <ComboBox ItemsSource="{Binding LanguageOptions}"
                      SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                      Width="145"
                      ToolTip.Tip="{Binding Localization[language.label]}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="{Binding Localization[button.help]}" Command="{Binding HelpCommand}" />
            <Button Content="{Binding Localization[button.analyze]}" Command="{Binding AnalyzeCommand}" IsEnabled="{Binding CanAnalyzeResources}" />
            <Button Content="{Binding Localization[button.buildPreview]}" Command="{Binding BuildPreviewCommand}" IsEnabled="{Binding CanBuildPreviewPlan}" />
            <Button Content="{Binding Localization[button.apply]}" IsEnabled="{Binding CanApplyPlan}" Click="Apply_Click" />
            <Button Content="{Binding Localization[button.cancel]}" Command="{Binding CancelCommand}" IsEnabled="{Binding IsBusy}" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Horizontal" Spacing="8">
          <Button Content="{Binding Localization[project.open]}" Click="OpenProject_Click" IsEnabled="{Binding CanEditProject}" />
          <Button Content="{Binding Localization[project.save]}" Click="SaveProject_Click" IsEnabled="{Binding CanEditProject}" />
          <Button Content="{Binding Localization[project.saveAs]}" Click="SaveProjectAs_Click" IsEnabled="{Binding CanEditProject}" />
          <Button Content="{Binding Localization[project.clear]}" Click="ClearProject_Click" IsEnabled="{Binding CanEditProject}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="340,*" ColumnSpacing="12" Margin="12">
      <ScrollViewer Grid.Column="0">
        <StackPanel Spacing="12">
          <Border Padding="12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="6">
            <StackPanel Spacing="8">
              <TextBlock Classes="section-title" Text="{Binding Localization[section.options]}" />
              <TextBlock Text="{Binding Localization[field.newMergedResourceName]}" />
              <TextBox Text="{Binding TargetResource, Mode=TwoWay}" />
              <TextBlock Text="{Binding Localization[field.targetPrefix]}" />
              <TextBox Text="{Binding TargetPrefix, Mode=TwoWay}" />
              <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              </Grid>
              <CheckBox Content="{Binding Localization[option.savePlan]}" IsChecked="{Binding SavePlan, Mode=TwoWay}" />
              <CheckBox Content="{Binding Localization[option.copyResources]}" IsChecked="{Binding CopyResourcesToOutputBeforeRename, Mode=TwoWay}"
                        ToolTip.Tip="{Binding Localization[option.copyResources.tooltip]}"/>
              <CheckBox Content="{Binding Localization[option.optimizeYmt]}"
                        IsChecked="{Binding OptimizeYmtUsage, Mode=TwoWay}"
                        ToolTip.Tip="{Binding Localization[option.optimizeYmt.tooltip]}" />
              <Expander Header="{Binding Localization[section.advanced]}" HorizontalAlignment="Stretch">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                  <Button Content="{Binding Localization[button.exportXml]}"
                          Command="{Binding ExportXmlCommand}"
                          IsEnabled="{Binding CanExportXml}"
                          HorizontalAlignment="Stretch" />
                  <TextBlock Text="{Binding Localization[field.malePrefix]}" />
                  <TextBox Text="{Binding MalePrefix, Mode=TwoWay}" />
                  <TextBlock Text="{Binding Localization[field.femalePrefix]}" />
                  <TextBox Text="{Binding FemalePrefix, Mode=TwoWay}" />
                  <CheckBox Content="{Binding Localization[option.debugClient]}" IsChecked="{Binding IncludeDebugClient, Mode=TwoWay}" ToolTip.Tip="{Binding Localization[option.debugClient.tooltip]}"/>
                  <CheckBox Content="{Binding Localization[option.previewYmtXml]}" IsChecked="{Binding IncludeYmtXml, Mode=TwoWay}" />
                  <CheckBox Content="{Binding Localization[option.overwriteXml]}" IsChecked="{Binding OverwriteXml, Mode=TwoWay}" />
                  <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{Binding Localization[field.maxComponentDrawables]}" />
                    <NumericUpDown Minimum="1" Maximum="4096" Value="{Binding MaxDrawablesPerComponent, Mode=TwoWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding Localization[field.maxPropDrawables]}" />
                    <NumericUpDown Minimum="1" Maximum="4096" Value="{Binding MaxDrawablesPerProp, Mode=TwoWay}" />
                  </StackPanel>
                </StackPanel>
              </Expander>
            </StackPanel>
          </Border>

          <Border Padding="12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="6">
            <StackPanel Spacing="8">
              <TextBlock Classes="section-title" Text="{Binding Localization[section.paths]}" />
              <TextBlock Text="{Binding Localization[field.planJson]}" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding PlanPath, Mode=TwoWay}" />
                <Button Grid.Column="1" Content="..." Click="BrowsePlan_Click" />
              </Grid>
              <TextBlock Text="{Binding Localization[field.outputLocation]}" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding OutputPath, Mode=TwoWay}" />
                <Button Grid.Column="1" Content="..." Click="BrowseOutput_Click" />
              </Grid>
              <TextBlock Text="{Binding Localization[field.backupLocation]}" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding BackupRoot, Mode=TwoWay}" />
                <Button Grid.Column="1" Content="..." Click="BrowseBackup_Click" />
              </Grid>
            </StackPanel>
          </Border>
          <Border Padding="12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="6">
            <StackPanel Spacing="8">
              <TextBlock Classes="section-title" Text="{Binding Localization[section.restoreManifest]}" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0" Text="{Binding RestoreManifestPath, Mode=TwoWay}" />
                <Button Grid.Column="1" Content="..." Click="BrowseRestoreManifest_Click" />
              </Grid>
              <Button Content="{Binding Localization[button.restoreBackup]}" Command="{Binding RestoreCommand}" IsEnabled="{Binding CanRestoreBackup}" HorizontalAlignment="Stretch" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="12">
        <Border Grid.Row="0" Padding="12" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="6">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
            <TextBlock Text="{Binding Status}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock Grid.Column="0" Text="{Binding CurrentStage}" />
              <TextBlock Grid.Column="1" Text="{Binding ActivePath}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            </Grid>
            <ProgressBar Grid.Row="2"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressValue}" />
            <ProgressBar Grid.Row="3"
                         Height="3"
                         Minimum="0"
                         Maximum="100"
                         IsVisible="{Binding IsBusy}"
                         IsIndeterminate="True" />
          </Grid>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
          <TabItem Header="{Binding Localization[tab.resources]}">
            <Grid RowDefinitions="Auto,*" RowSpacing="10" Margin="2">
              <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="8">
                <Button Grid.Column="0" Content="{Binding Localization[resource.add]}" Click="BrowseResources_Click" />
                <Button Grid.Column="1" Content="{Binding Localization[resource.remove]}" Click="RemoveResource_Click" />
                <Button Grid.Column="2" Content="{Binding Localization[resource.clear]}" Click="ClearResources_Click" />
                <Button Grid.Column="3" Content="{Binding Localization[resource.moveUp]}" Command="{Binding MoveResourceUpCommand}" IsEnabled="{Binding CanMoveResourceUp}" />
                <Button Grid.Column="4" Content="{Binding Localization[resource.moveDown]}" Command="{Binding MoveResourceDownCommand}" IsEnabled="{Binding CanMoveResourceDown}" />
                <TextBlock Grid.Column="5"
                           Text="{Binding Localization[resource.orderHint]}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
              </Grid>
              <ListBox Grid.Row="1"
                       ItemsSource="{Binding ResourcePaths}"
                       SelectedItem="{Binding SelectedResourcePath, Mode=TwoWay}" />
            </Grid>
          </TabItem>
          <TabItem Header="{Binding Localization[tab.summary]}">
            <ListBox ItemsSource="{Binding SummaryLines}" />
          </TabItem>
          <TabItem Header="{Binding Localization[tab.repackMap]}">
            <Grid RowDefinitions="2*,4,*" RowSpacing="6" Margin="2">
              <ScrollViewer Grid.Row="0"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                <controls:RepackMapControl Report="{Binding RepackReport}"
                                           Localization="{Binding Localization}"
                                           MinHeight="240" />
              </ScrollViewer>
              <GridSplitter Grid.Row="1"
                            ResizeDirection="Rows"
                            HorizontalAlignment="Stretch"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
              <ListBox Grid.Row="2"
                       ItemsSource="{Binding RepackReportLines}"
                       ScrollViewer.HorizontalScrollBarVisibility="Auto"
                       ScrollViewer.VerticalScrollBarVisibility="Visible">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Padding" Value="2,0" />
                    <Setter Property="Focusable" Value="False" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontFamily="Consolas, DejaVu Sans Mono"
                               FontSize="12"
                               LineHeight="15"
                               TextWrapping="NoWrap" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </TabItem>
          <TabItem Header="{Binding Localization[tab.warnings]}">
            <ListBox ItemsSource="{Binding Warnings}" />
          </TabItem>
          <TabItem Header="{Binding Localization[tab.errors]}">
            <ListBox ItemsSource="{Binding Errors}" />
          </TabItem>
          <!-- <TabItem Header="Files">
            <ListBox ItemsSource="{Binding Files}" />
          </TabItem> -->
          <TabItem Header="{Binding Localization[tab.restore]}">
            <Grid RowDefinitions="Auto,*" RowSpacing="10" Margin="2">
              <TextBox Grid.Row="0"
                       Text="{Binding RestoreSummaryText}"
                       IsReadOnly="True"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="112"
                       MaxHeight="180" />
              <ListBox Grid.Row="1"
                       ItemsSource="{Binding RestoreActionLines}"
                       ScrollViewer.HorizontalScrollBarVisibility="Auto"
                       ScrollViewer.VerticalScrollBarVisibility="Visible">
                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Padding" Value="2,0" />
                    <Setter Property="Focusable" Value="False" />
                  </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}"
                               FontFamily="Consolas, DejaVu Sans Mono"
                               FontSize="12"
                               LineHeight="15"
                               TextWrapping="NoWrap" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </TabItem>
          <TabItem Header="{Binding Localization[tab.log]}">
            <ListBox ItemsSource="{Binding LogLines}" >
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="MinHeight" Value="0" />
                  <Setter Property="Padding" Value="2,0" />
                  <Setter Property="Focusable" Value="False" />
                </Style>
              </ListBox.Styles>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             FontFamily="Consolas, DejaVu Sans Mono"
                             FontSize="12"
                             LineHeight="15"
                             TextWrapping="NoWrap" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </TabItem>
        </TabControl>
      </Grid>
    </Grid>
  </Grid>
</Window>
